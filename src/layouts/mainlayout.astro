    </main>

    <footer style="text-align: center; padding: 40px; border-top: 1px solid #eee; color: #666;">
        <!-- AdSense अप्रूवल के लिए सभी ज़रूरी 4 लिंक्स -->
        <div style="margin-bottom: 15px;">
            <a href="/about" style="margin: 0 10px; color: #666; text-decoration: underline;">About Us</a>
            <a href="/privacy-policy" style="margin: 0 10px; color: #666; text-decoration: underline;">Privacy Policy</a>
            <a href="/terms" style="margin: 0 10px; color: #666; text-decoration: underline;">Terms of Service</a>
            <a href="/contact" style="margin: 0 10px; color: #666; text-decoration: underline;">Contact Us</a>
        </div>
        <p>&copy; 2026 Kailash Bhisekar. All Rights Reserved.</p>
    </footer>

</body>
</html>
