const { title, description = "Finance, Business, AI Tools, and Online Earning Insights by The KB Global." } = Astro.props;
---

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <!-- SEO मेटा डिस्क्रिप्शन (Google Search के लिए अनिवार्य) -->
    <meta name="description" content={description} />
</head>
<body style="margin: 0; font-family: sans-serif;">
    
    <nav style="text-align: center; padding: 20px 0; border-bottom: 2px solid #000; background: #fff;">
        <a href="/" style="margin: 0 15px; text-decoration: none; color: black; font-weight: bold;">Home</a>
        <a href="/finance" style="margin: 0 15px; text-decoration: none; color: black; font-weight: bold;">Finance</a>
        <a href="/business" style="margin: 0 15px; text-decoration: none; color: black; font-weight: bold;">Business</a>
        <a href="/ai-tools" style="margin: 0 15px; text-decoration: none; color: black; font-weight: bold;">AI Tools</a>
        <!-- Online Earning का लिंक जोड़ा गया -->
        <a href="/online-earning" style="margin: 0 15px; text-decoration: none; color: black; font-weight: bold;">Online Earning</a>
    </nav>

    <main style="max-width: 800px; margin: 40px auto; padding: 0 20px;">
        <!-- आपके पेजेज का कंटेंट यहाँ लोड होगा -->
