<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Global Finance & AI Insights Platform</title>
    <!-- Favicon Added -->
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <style>
        :root {
            --black-main: #000000;
            --grey-dark: #121212;
            --grey-light: #f5f5f5;
            --border-heavy: #000000;
            --border-light: #e0e0e0;
            --accent-red: #ff3b30;
            --accent-green: #00cc44;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Helvetica Neue', Arial, sans-serif;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            background-color: #ffffff;
            color: var(--black-main);
            line-height: 1.4;
        }

        /* 1. लाइव स्टॉक टिकर स्टाइल */
        .market-ticker {
            background-color: var(--black-main);
            color: #ffffff;
            padding: 10px 20px;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 1px;
            display: flex;
            justify-content: space-between;
            border-bottom: 2px solid #222;
        }

        .ticker-data {
            display: flex;
            gap: 25px;
        }

        .ticker-data span {
            color: var(--accent-green);
            font-variant-numeric: tabular-nums;
        }

        /* 2. घूमने वाली ट्रेंडिंग न्यूज़ (Marquee) का स्टाइल */
        .breaking-news-bar {
            background-color: var(--accent-red);
            color: white;
            padding: 8px 20px;
            font-size: 13px;
            font-weight: bold;
            display: flex;
            align-items: center;
            overflow: hidden;
            border-bottom: 4px solid var(--black-main);
        }

        .breaking-label {
            background: #000;
            padding: 2px 10px;
            text-transform: uppercase;
            font-size: 11px;
            letter-spacing: 1px;
            margin-right: 15px;
            white-space: nowrap;
        }

        /* न्यूज़ को घुमाने का एनिमेशन */
        .marquee-text {
            white-space: nowrap;
            display: inline-block;
            animation: marquee 25s linear infinite;
            padding-left: 100%;
        }

        .marquee-text:hover {
            animation-play-state: paused; 
            cursor: pointer;
        }

        @keyframes marquee {
            0% { transform: translate3d(0, 0, 0); }
            100% { transform: translate3d(-100%, 0, 0); }
        }

        .marquee-item {
            margin-right: 50px;
            display: inline-block;
        }

        .marquee-item a {
            color: white;
            text-decoration: none;
        }

        /* Header & Logo - MADE STICKY */
        header {
            padding: 25px 20px;
            background: #ffffff;
            border-bottom: 3px solid var(--black-main);
            position: sticky; /* Sticky Header Fix */
            top: 0;
            z-index: 1000;
        }

        .header-wrap {
            max-width: 1400px;
            margin: 0 auto;
            text-align: center;
        }

        .site-logo {
            font-size: 42px;
            font-weight: 900;
            letter-spacing: -1.5px;
            text-transform: uppercase;
            display: inline-block;
            border-bottom: 5px solid var(--black-main);
            padding-bottom: 5px;
            margin-bottom: 20px;
        }

        nav {
            border-top: 1px solid var(--border-light);
            padding-top: 15px;
        }

        .nav-menu {
            display: flex;
            justify-content: center;
            list-style: none;
            gap: 40px;
        }

        .nav-menu a {
            text-decoration: none;
            color: var(--black-main);
            font-weight: 800;
            font-size: 14px;
            text-transform: uppercase;
        }

        /* Layout Grid */
        .layout-grid {
            max-width: 1400px;
            margin: 30px auto;
            padding: 0 20px;
            display: grid;
            grid-template-columns: 3fr 1fr;
            gap: 40px;
        }

        .editorial-feed {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            border-bottom: 3px solid var(--black-main);
            padding-bottom: 35px;
        }

        .lead-story {
            grid-column: span 2;
            border-bottom: 1px solid var(--border-light);
            padding-bottom: 30px;
        }

        .category-tag {
            font-size: 12px;
            font-weight: 800;
            text-transform: uppercase;
            color: var(--black-main);
            background: var(--grey-light);
            padding: 2px 6px;
            display: inline-block;
            margin-bottom: 8px;
        }

        /* TEXT WRAPPING FIXES FOR MOBILE */
        .lead-title {
            font-size: 40px;
            font-weight: 800;
            line-height: 1.15;
            margin-bottom: 15px;
            overflow-wrap: break-word; /* Text cut fix */
            word-wrap: break-word;
            hyphens: auto;
        }

        .lead-title a {
            text-decoration: none;
            color: inherit;
        }

        .lead-excerpt {
            font-size: 17px;
            color: #333333;
        }

        .sub-story {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .sub-title {
            font-size: 22px;
            font-weight: 800;
            overflow-wrap: break-word; /* Text cut fix */
            word-wrap: break-word;
            hyphens: auto;
        }

        .sub-story a {
            text-decoration: none;
            color: inherit;
        }

        .sidebar-right {
            border-left: 1px solid var(--border-light);
            padding-left: 30px;
        }

        .sidebar-heading {
            font-size: 16px;
            font-weight: 900;
            text-transform: uppercase;
            border-bottom: 3px solid var(--black-main);
            padding-bottom: 8px;
            margin-bottom: 25px;
        }

        .trending-list {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 25px;
        }

        .trending-item {
            border-bottom: 1px solid var(--border-light);
            padding-bottom: 15px;
        }

        /* Category Blocks */
        .category-block {
            max-width: 1400px;
            margin: 50px auto;
            padding: 0 20px;
            scroll-margin-top: 140px;
        }

        .category-header {
            border-bottom: 3px solid var(--black-main);
            margin-bottom: 30px;
        }

        .category-header h2 {
            font-size: 22px;
            font-weight: 900;
            text-transform: uppercase;
            background: var(--black-main);
            color: #ffffff;
            display: inline-block;
            padding: 8px 20px;
        }

        .four-col-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 30px;
        }

        /* MOBILE RESPONSIVENESS FIXES */
        @media (max-width: 1100px) {
            .layout-grid { grid-template-columns: 1fr; }
            .sidebar-right { border-left: none; padding-left: 0; margin-top: 30px; }
            .four-col-grid { grid-template-columns: repeat(2, 1fr); }
        }

        @media (max-width: 768px) {
            .nav-menu { flex-wrap: wrap; gap: 15px 25px; }
            .editorial-feed { grid-template-columns: 1fr; }
            .lead-story { grid-column: span 1; }
            .lead-title { font-size: 30px; }
            .four-col-grid { grid-template-columns: 1fr; }
            .layout-grid { padding-top: 20px; } /* Added Padding */
            .sub-story { margin-bottom: 25px; } /* Card Spacing */
        }
    </style>
