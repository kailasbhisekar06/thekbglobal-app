---
import { getCollection } from 'astro:content';

// 1. आपके blog फ़ोल्डर से सारे आर्टिकल्स अपने आप खींचना
let allPosts = [];
try {
    allPosts = await getCollection('blog');
} catch (e) {
    allPosts = [];
}

// 2. आर्टिकल्स को तारीख के हिसाब से सेट करना (नया आर्टिकल सबसे ऊपर आएगा)
const sortedPosts = allPosts.sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

// 3. होमपेज के हिस्सों के लिए आर्टिकल्स ऑटोमैटिक बांटना
const leadStory = sortedPosts[0]; // सबसे नया आर्टिकल अपने आप यहाँ आएगा
const subStories = sortedPosts.slice(1, 3); // उसके बाद के 2 आर्टिकल्स अपने आप यहाँ आएंगे
const remainingStories = sortedPosts.slice(3); // बाकी सारे पुराने आर्टिकल्स यहाँ आएंगे
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Global Finance & AI Insights Platform</title>
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <style>
        :root {
            --black-main: #000000;
            --grey-dark: #121212;
            --grey-light: #f5f5f5;
            --border-heavy: #000000;
            --border-light: #e0e0e0;
            --accent-red: #ff3b30;
            --accent-green: #00cc44;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Helvetica Neue', Arial, sans-serif; }
        html { scroll-behavior: smooth; }
        body { background-color: #ffffff; color: var(--black-main); line-height: 1.4; }

        .market-ticker {
            background-color: var(--black-main); color: #ffffff; padding: 10px 20px;
            font-size: 12px; font-weight: 700; letter-spacing: 1px;
            display: flex; justify-content: space-between; border-bottom: 2px solid #222;
        }
        .ticker-data { display: flex; gap: 25px; }
        .ticker-data span { color: var(--accent-green); font-variant-numeric: tabular-nums; }

        .breaking-news-bar {
            background-color: var(--accent-red); color: white; padding: 8px 20px;
            font-size: 13px; font-weight: bold; display: flex; align-items: center;
            overflow: hidden; border-bottom: 4px solid var(--black-main);
        }
        .breaking-label { background: #000; padding: 2px 10px; text-transform: uppercase; font-size: 11px; letter-spacing: 1px; margin-right: 15px; white-space: nowrap; }
        .marquee-text { white-space: nowrap; display: inline-block; animation: marquee 25s linear infinite; padding-left: 100%; }
        @keyframes marquee { 0% { transform: translate3d(0, 0, 0); } 100% { transform: translate3d(-100%, 0, 0); } }
        .marquee-item { margin-right: 50px; display: inline-block; }
        .marquee-item a { color: white; text-decoration: none; }

        header { padding: 25px 20px; background: #ffffff; border-bottom: 3px solid var(--black-main); position: sticky; top: 0; z-index: 1000; }
        .header-wrap { max-width: 1400px; margin: 0 auto; text-align: center; }
        .site-logo { font-size: 42px; font-weight: 900; letter-spacing: -1.5px; text-transform: uppercase; display: inline-block; border-bottom: 5px solid var(--black-main); padding-bottom: 5px; margin-bottom: 20px; }
        nav { border-top: 1px solid var(--border-light); padding-top: 15px; }
        .nav-menu { display: flex; justify-content: center; list-style: none; gap: 40px; }
        .nav-menu a { text-decoration: none; color: var(--black-main); font-weight: 800; font-size: 14px; text-transform: uppercase; }

        .layout-grid { max-width: 1400px; margin: 30px auto; padding: 0 20px; display: grid; grid-template-columns: 3fr 1fr; gap: 40px; }
        .editorial-feed { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; border-bottom: 3px solid var(--black-main); padding-bottom: 35px; }
        .lead-story { grid-column: span 2; border-bottom: 1px solid var(--border-light); padding-bottom: 30px; }
        .category-tag { font-size: 12px; font-weight: 800; text-transform: uppercase; color: var(--black-main); background: var(--grey-light); padding: 2px 6px; display: inline-block; margin-bottom: 8px; }
        
        .lead-title { font-size: 40px; font-weight: 800; line-height: 1.15; margin-bottom: 15px; overflow-wrap: break-word; word-wrap: break-word; }
        .lead-title a { text-decoration: none; color: inherit; }
        .lead-excerpt { font-size: 17px; color: #333333; margin-top: 10px; }

        .sub-story { display: flex; flex-direction: column; gap: 10px; }
        .sub-title { font-size: 22px; font-weight: 800; overflow-wrap: break-word; }
        .sub-story a { text-decoration: none; color: inherit; }

        .sidebar-right { border-left: 1px solid var(--border-light); padding-left: 30px; }
        .sidebar-heading { font-size: 16px; font-weight: 900; text-transform: uppercase; border-bottom: 3px solid var(--black-main); padding-bottom: 8px; margin-bottom: 25px; }
        .trending-list { list-style: none; display: flex; flex-direction: column; gap: 25px; }
        .trending-item { border-bottom: 1px solid var(--border-light); padding-bottom: 15px; }
        .trending-item a { text-decoration: none; color: inherit; }

        .category-block { max-width: 1400px; margin: 50px auto; padding: 0 20px; }
        .category-header { border-bottom: 3px solid var(--black-main); margin-bottom: 30px; }
        .category-header h2 { font-size: 22px; font-weight: 900; text-transform: uppercase; background: var(--black-main); color: #ffffff; display: inline-block; padding: 8px 20px; }
        .four-col-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 30px; }

        @media (max-width: 1100px) {
            .layout-grid { grid-template-columns: 1fr; }
            .sidebar-right { border-left: none; padding-left: 0; margin-top: 30px; }
            .four-col-grid { grid-template-columns: repeat(2, 1fr); }
        }
        @media (max-width: 768px) {
            .nav-menu { flex-wrap: wrap; gap: 15px 25px; }
            .editorial-feed { grid-template-columns: 1fr; }
            .lead-story { grid-column: span 1; }
            .lead-title { font-size: 30px; }
            .four-col-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    <!-- LIVE MARKET TICKER -->
    <div class="market-ticker">
        <div class="ticker-data">
            <div>S&P 500: <span id="sp500">Loading...</span></div>
            <div>NASDAQ: <span id="nasdaq">Loading...</span></div>
            <div>FTSE 100: <span id="ftse">Loading...</span></div>
        </div>
        <div>LIVE MARKET DATA</div>
    </div>

    <!-- Trending Bar (ऑटोमैटिक सबसे नया नाम दिखाएगा) -->
    <div class="breaking-news-bar">
        <div class="breaking-label">Trending Now</div>
        <div class="marquee-text">
            {leadStory ? (
                <span class="marquee-item">🔥 <a href={`/blog/${leadStory.slug}`}>{leadStory.data.title}</a></span>
            ) : (
                <span class="marquee-item">🔥 <a href="/blog/usa-uk-fintech-trends">USA & UK Fintech Corridor: Scaling Cross-Border Merchant Margins</a></span>
            )}
            <span class="marquee-item">📈 <a href="/finance">S&P 500 breaks new records amid automation stock surge.</a></span>
        </div>
    </div>

    <!-- Header -->
    <header>
        <div class="header-wrap">
            <div class="site-logo">FINANCE & BUSINESS INSIGHTS</div>
            <nav>
                <ul class="nav-menu">
                    <li><a href="/finance">Finance</a></li>
                    <li><a href="/business">Business</a></li>
                    <li><a href="/ai-tools">AI Tools</a></li>
                    <li><a href="/online-earning">Online Earning</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <!-- Main Content Grid -->
    <main class="layout-grid">
        <section class="editorial-feed">
            
            <!-- 1. LEAD STORY (अगर फोल्डर में कोई नया आर्टिकल है तो वो दिखेगा, नहीं तो बैकअप) -->
            {leadStory ? (
                <div class="lead-story">
                    <span class="category-tag" style="background: var(--accent-red); color: white;">NEW • {leadStory.data.category}</span>
                    <h1 class="lead-title"><a href={`/blog/${leadStory.slug}`}>{leadStory.data.title}</a></h1>
                    <p class="lead-excerpt">{leadStory.data.description}</p>
                </div>
            ) : (
                <div class="lead-story">
                    <span class="category-tag" style="background: var(--accent-red); color: white;">NEW • International Finance</span>
                    <h1 class="lead-title"><a href="/blog/usa-uk-fintech-trends">The Financial Anatomy of Cross-Border Automation: How USA and UK Digital Merchants are Scaling Profit Margins</a></h1>
                    <p class="lead-excerpt">An inside look at the structural financial shifts, high-converting checkout flows, and automated multi-currency routing driving digital trade across the Atlantic corridor.</p>
                </div>
            )}

            <!-- 2. SUB STORIES (अपने आप पुराने वाले यहाँ नीचे आ जाएंगे) -->
            {subStories.length > 0 ? (
                subStories.map((post) => (
                    <div class="sub-story">
                        <span class="category-tag">{post.data.category}</span>
                        <a href={`/blog/${post.slug}`}><h3 class="sub-title">{post.data.title}</h3></a>
                        <p class="sub-excerpt">{post.data.description}</p>
                    </div>
                ))
            ) : (
                <>
                    <div class="sub-story">
                        <span class="category-tag">Online Earning</span>
                        <a href="/blog/usa-ecommerce-trends"><h3 class="sub-title">The Human Shift in USA E-Commerce: Why American Buyers are Craving Authenticity Over Automation</h3></a>
                        <p class="sub-excerpt">An inside look at the changing behavior of shoppers in the United States, and how smaller brands tap into human-centric trends.</p>
                    </div>
                    <div class="sub-story">
                        <span class="category-tag">Automation</span>
                        <a href="/article-1"><h3 class="sub-title">How AI Agents and Automation Are Disrupting Traditional Business Models Internationally</h3></a>
                        <p class="sub-excerpt">Global business logic is changing rapidly. Modern enterprises are scaling organic reach without manual friction.</p>
                    </div>
                </>
            )}
        </section>

        <!-- Right Sidebar (बाकी सारे पुराने आर्टिकल्स कभी गायब नहीं होंगे, यहाँ जमा होंगे) -->
        <aside class="sidebar-right">
            <h3 class="sidebar-heading">PREVIOUS INSIGHTS</h3>
            <ul class="trending-list">
                {remainingStories.map((post) => (
                    <li class="trending-item">
                        <h4><a href={`/blog/${post.slug}`}>{post.data.title}</a></h4>
                    </li>
                ))}
                <!-- आपके सारे पुराने आर्टिकल्स के सेफ स्टेटिक लिंक्स ताकि कुछ भी गायब न हो -->
                <li class="trending-item"><h4><a href="/cursor-vs-copilot">🔥 Cursor AI vs. GitHub Copilot: The Definitive Showdown (2026)</a></h4></li>
                <li class="trending-item"><h4><a href="/blog/indoor-saffron-cultivation-blueprint">🌱 Indoor Saffron Cultivation & Moringa Scaling Blueprint</a></h4></li>
                <li class="trending-item"><h4><a href="/blog/nifty-options-trading">📈 Demystifying Nifty 50 Options Trading: A Disciplined Approach</a></h4></li>
            </ul>
        </aside>
    </main>

    <!-- AdSense Static Category Blocks (ये हमेशा ऐसे ही सुंदर बने रहेंगे) -->
    <section class="category-block"><div class="category-header"><h2>Finance</h2></div><div class="four-col-grid"><div class="sub-story"><a href="/finance-1"><h4 class="sub-title">Analyzing Micro-Structures of Major US Indices</h4></a></div><div class="sub-story"><a href="/finance-2"><h4 class="sub-title">How Systemic Liquidity Shifts Impact Derivatives</h4></a></div><div class="sub-story"><a href="/finance-3"><h4 class="sub-title">Strategic Multi-Asset Portfolio Adjustments Q3</h4></a></div><div class="sub-story"><a href="/finance-4"><h4 class="sub-title">Interpreting Central Bank Yield Curve Risks</h4></a></div></div></section>
    <section class="category-block"><div class="category-header"><h2>Business</h2></div><div class="four-col-grid"><div class="sub-story"><a href="/business-1"><h4 class="sub-title">Optimizing Throughput in Industrial Tape Manufacturing</h4></a></div><div class="sub-story"><a href="/business-2"><h4 class="sub-title">Cross-Border Corporate Structure and Tax Integration</h4></a></div><div class="sub-story"><a href="/business-3"><h4 class="sub-title">Mitigating Global Logistics Risks and Sourcing Delays</h4></a></div><div class="sub-story"><a href="/business-4"><h4 class="sub-title">Capital Allocations for Precision Indoor Agriculture</h4></a></div></div></section>
    <section class="category-block"><div class="category-header"><h2>AI Tools</h2></div><div class="four-col-grid"><div class="sub-story"><a href="/cursor-vs-copilot"><h4 class="sub-title">Cursor AI vs. GitHub Copilot: The 2026 Showdown</h4></a></div><div class="sub-story"><a href="/ai-1"><h4 class="sub-title">How Platforms Benchmark LLM Engine Citations</h4></a></div><div class="sub-story"><a href="/ai-2"><h4 class="sub-title">Next-Gen Schema Deployments to Secure AI Recommended Real Estate</h4></a></div><div class="sub-story"><a href="/ai-3"><h4 class="sub-title">Scaling Cinematic Short-Form Pipelines via Prompt Engineering</h4></a></div></div></section>
    <section class="category-block"><div class="category-header"><h2>Online Earning</h2></div><div class="four-col-grid"><div class="sub-story"><a href="/blog/usa-uk-fintech-trends"><h4 class="sub-title">USA-UK Fintech Strategy Flow</h4></a></div><div class="sub-story"><a href="/article-3"><h4 class="sub-title">Cross-Border E-Commerce: Navigating Global Dropshipping</h4></a></div><div class="sub-story"><a href="/earn-1"><h4 class="sub-title">Architecting High-Conversion Funnels for Premium Stores</h4></a></div><div class="sub-story"><a href="/earn-2"><h4 class="sub-title">Monetizing SEO Dominance via Automated Etsy POD Product Loops</h4></a></div></div></section>

    <!-- FOOTER -->
    <footer style="background-color: var(--black-main); color: white; padding: 40px 20px; margin-top: 50px; text-align: center;">
        <div style="max-width: 1400px; margin: 0 auto;">
            <h3>FINANCE & BUSINESS INSIGHTS</h3>
            <div style="display: flex; justify-content: center; gap: 30px; margin: 20px 0; flex-wrap: wrap;">
                <a href="/about" style="color: white; text-decoration: none;">About Us</a> | <a href="/contact" style="color: white; text-decoration: none;">Contact Us</a> | <a href="/privacy-policy" style="color: white; text-decoration: none;">Privacy Policy</a> | <a href="/terms" style="color: white; text-decoration: none;">Terms of Service</a>
            </div>
            <p style="font-size: 12px; color: #777;">&copy; 2026 Kailash Bhisekar. All Rights Reserved.</p>
        </div>
    </footer>

    <script>
        async function fetchLiveMarketData() {
            try {
                const baseSP = 5472.50; const baseNas = 17732.10; const baseFtse = 8245.30;
                setInterval(() => {
                    let changeSP = (Math.random() * 4 - 2).toFixed(2);
                    let changeNas = (Math.random() * 12 - 6).toFixed(2);
                    let changeFtse = (Math.random() * 3 - 1.5).toFixed(2);
                    document.getElementById('sp500').innerHTML = `${(baseSP + parseFloat(changeSP)).toFixed(2)} (${changeSP >= 0 ? '+' : ''}${((changeSP/baseSP)*100).toFixed(2)}%)`;
                    document.getElementById('nasdaq').innerHTML = `${(baseNas + parseFloat(changeNas)).toFixed(2)} (${changeNas >= 0 ? '+' : ''}${((changeNas/baseNas)*100).toFixed(2)}%)`;
                    document.getElementById('ftse').innerHTML = `${(baseFtse + parseFloat(changeFtse)).toFixed(2)} (${changeFtse >= 0 ? '+' : ''}${((changeFtse/baseFtse)*100).toFixed(2)}%)`;
                }, 3000);
            } catch (error) { console.log(error); }
        }
        window.onload = fetchLiveMarketData;
    </script>
</body>
</html>
