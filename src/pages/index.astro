<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Global Finance & AI Insights Platform</title>
    <style>
        /* Bloomberg-Inspired Professional Design System */
        :root {
            --black-main: #000000;
            --grey-dark: #121212;
            --grey-light: #f5f5f5;
            --border-heavy: #000000;
            --border-light: #e0e0e0;
            --accent-red: #ff3b30;
            --accent-green: #00cc44;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Helvetica Neue', Arial, sans-serif;
        }

        html {
            scroll-behavior: smooth; /* मेनू क्लिक पर स्मूथ स्क्रॉल */
        }

        body {
            background-color: #ffffff;
            color: var(--black-main);
            line-height: 1.4;
        }

        /* 1. लाइव स्टॉक टिकर स्टाइल */
        .market-ticker {
            background-color: var(--black-main);
            color: #ffffff;
            padding: 10px 20px;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 1px;
            display: flex;
            justify-content: space-between;
            border-bottom: 2px solid #222;
        }

        .ticker-data {
            display: flex;
            gap: 25px;
        }

        .ticker-data span {
            color: var(--accent-green);
            font-variant-numeric: tabular-nums;
        }

        /* 2. परफेक्ट ब्रेकिंग न्यूज़ टिकर (बिना टेक्स्ट दबे स्मूथ एनिमेशन) */
        .breaking-news-bar {
            background-color: var(--accent-red);
            color: white;
            height: 42px; /* फिक्स हाइट ताकि टेक्स्ट बिल्कुल परफेक्ट दिखे */
            display: flex;
            align-items: center;
            overflow: hidden;
            position: relative;
            border-bottom: 3px solid var(--black-main);
        }

        .breaking-label {
            background: #000000;
            color: #ffffff;
            padding: 0 18px;
            height: 100%;
            display: flex;
            align-items: center;
            text-transform: uppercase;
            font-size: 11px;
            font-weight: 900;
            letter-spacing: 1px;
            z-index: 10;
            box-shadow: 5px 0 15px rgba(0,0,0,0.3);
        }

        .marquee-container {
            overflow: hidden;
            width: 100%;
            display: flex;
            align-items: center;
        }

        .marquee-text {
            white-space: nowrap;
            display: inline-block;
            animation: marquee 30s linear infinite;
            padding-left: 20px;
        }

        .marquee-text:hover {
            animation-play-state: paused; /* माउस ले जाने पर न्यूज़ रुकेगी */
        }

        @keyframes marquee {
            0% { transform: translate3d(0, 0, 0); }
            100% { transform: translate3d(-100%, 0, 0); }
        }

        .marquee-item {
            margin-right: 60px;
            display: inline-block;
            font-size: 14px;
            font-weight: 600;
            letter-spacing: 0.2px;
        }

        .marquee-item a {
            color: white;
            text-decoration: none;
        }
        
        .marquee-item a:hover {
            text-decoration: underline;
        }

        /* Bloomberg Style Heavy Header */
        header {
            padding: 25px 20px;
            background: #ffffff;
            border-bottom: 3px solid var(--black-main);
        }

        .header-wrap {
            max-width: 1400px;
            margin: 0 auto;
            text-align: center;
        }

        .site-logo {
            font-size: 42px;
            font-weight: 900;
            letter-spacing: -1.5px;
            text-transform: uppercase;
            display: inline-block;
            border-bottom: 5px solid var(--black-main);
            padding-bottom: 5px;
            margin-bottom: 20px;
        }

        /* Navigation Links */
        nav {
            border-top: 1px solid var(--border-light);
            padding-top: 15px;
        }

        .nav-menu {
            display: flex;
            justify-content: center;
            list-style: none;
            gap: 40px;
        }

        .nav-menu a {
            text-decoration: none;
            color: var(--black-main);
            font-weight: 800;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .nav-menu a:hover {
            color: var(--accent-red);
        }

        /* Multi-Column Magazine Layout Container */
        .layout-grid {
            max-width: 1400px;
            margin: 30px auto;
            padding: 0 20px;
            display: grid;
            grid-template-columns: 3fr 1fr;
            gap: 40px;
        }

        /* Left Side: Editorial Feed */
        .editorial-feed {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            border-bottom: 3px solid var(--black-main);
            padding-bottom: 35px;
        }

        .lead-story {
            grid-column: span 2;
            border-bottom: 1px solid var(--border-light);
            padding-bottom: 30px;
        }

        .category-tag {
            font-size: 12px;
            font-weight: 800;
            text-transform: uppercase;
            color: var(--accent-red);
            letter-spacing: 0.5px;
            margin-bottom: 8px;
            display: block;
        }

        .lead-title {
            font-size: 40px;
            font-weight: 800;
            line-height: 1.15;
            letter-spacing: -0.8px;
            margin-bottom: 15px;
        }

        .lead-excerpt {
            font-size: 17px;
            color: #333333;
            max-width: 95%;
        }

        /* Secondary Grid Stories */
        .sub-story {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .sub-title {
            font-size: 22px;
            font-weight: 800;
            line-height: 1.25;
        }

        .sub-excerpt {
            font-size: 15px;
            color: #444444;
        }

        /* Right Side: Sidebar */
        .sidebar-right {
            border-left: 1px solid var(--border-light);
            padding-left: 30px;
        }

        .sidebar-heading {
            font-size: 16px;
            font-weight: 900;
            text-transform: uppercase;
            border-bottom: 3px solid var(--black-main);
            padding-bottom: 8px;
            margin-bottom: 25px;
        }

        .trending-list {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 25px;
        }

        .trending-item {
            border-bottom: 1px solid var(--border-light);
            padding-bottom: 15px;
        }

        .trending-item h4 {
            font-size: 15px;
            font-weight: 700;
            line-height: 1.4;
        }

        /* Deep-Dive Categories Grid Section */
        .category-block {
            max-width: 1400px;
            margin: 50px auto;
            padding: 0 20px;
            scroll-margin-top: 140px; /* क्लिक करने पर हेडर के पीछे कंटेंट नहीं छुपेगा */
        }

        .category-header {
            border-bottom: 3px solid var(--black-main);
            margin-bottom: 30px;
        }

        .category-header h2 {
            font-size: 22px;
            font-weight: 900;
            text-transform: uppercase;
            background: var(--black-main);
            color: #ffffff;
            display: inline-block;
            padding: 8px 20px;
        }

        .four-col-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 30px;
        }

        /* Footer Structure */
        footer {
            background-color: var(--black-main);
            color: #ffffff;
            padding: 60px 20px;
            margin-top: 80px;
            border-top: 6px solid var(--accent-red);
        }

        .footer-wrap {
            max-width: 1400px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 40px;
        }

        .footer-col h3 {
            font-size: 14px;
            text-transform: uppercase;
            margin-bottom: 25px;
            letter-spacing: 0.5px;
            border-bottom: 1px solid #222222;
            padding-bottom: 10px;
        }

        .footer-col ul {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .footer-col a {
            color: #999999;
            text-decoration: none;
            font-size: 14px;
        }

        .footer-col a:hover {
            color: #ffffff;
        }

        /* Strict Responsive Code for Tablets and Mobile Devices */
        @media (max-width: 1100px) {
            .layout-grid {
                grid-template-columns: 1fr;
            }
            .sidebar-right {
                border-left: none;
                padding-left: 0;
                margin-top: 30px;
            }
            .four-col-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 768px) {
            .nav-menu {
                flex-wrap: wrap;
                gap: 15px 25px;
            }
            .editorial-feed {
                grid-template-columns: 1fr;
            }
            .lead-story {
                grid-column: span 1;
            }
            .lead-title {
                font-size: 30px;
            }
            .four-col-grid {
                grid-template-columns: 1fr;
            }
            .footer-wrap {
                grid-template-columns: 1fr;
                gap: 35px;
            }
        }
    </style>
</head>
