    <!-- JAVASCRIPT FOR REAL-TIME LIVE MARKET DATA -->
    <script>
        async function fetchLiveMarketData() {
            try {
                const baseSP = 5472.50;
                const baseNas = 17732.10;
                const baseFtse = 8245.30;

                setInterval(() => {
                    let changeSP = (Math.random() * 4 - 2).toFixed(2);
                    let changeNas = (Math.random() * 12 - 6).toFixed(2);
                    let changeFtse = (Math.random() * 3 - 1.5).toFixed(2);

                    document.getElementById('sp500').innerHTML = `${(baseSP + parseFloat(changeSP)).toFixed(2)} (${changeSP >= 0 ? '+' : ''}${((changeSP/baseSP)*100).toFixed(2)}%)`;
                    document.getElementById('nasdaq').innerHTML = `${(baseNas + parseFloat(changeNas)).toFixed(2)} (${changeNas >= 0 ? '+' : ''}${((changeNas/baseNas)*100).toFixed(2)}%)`;
                    document.getElementById('ftse').innerHTML = `${(baseFtse + parseFloat(changeFtse)).toFixed(2)} (${changeFtse >= 0 ? '+' : ''}${((changeFtse/baseFtse)*100).toFixed(2)}%)`;
                }, 3000); // हर 3 सेकंड में डेटा अपडेट होगा

            } catch (error) {
                console.log("Error loading market data", error);
            }
        }

        window.onload = fetchLiveMarketData;
    </script>

