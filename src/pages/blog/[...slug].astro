---
// सीधे फ़ोल्डर से मर्कडाउन फ़ाइलों को लोड करना ताकि सिंगल पेज भी बिना कलेक्शन के चले
export async function getStaticPaths() {
  const markdownFiles = import.meta.glob('../../content/blog/**/*.md', { eager: true });
  
  return Object.entries(markdownFiles).map(([filepath, file]: any) => {
    const slug = filepath.replace('../../content/blog/', '').replace('.md', '');
    return {
      params: { slug },
      props: { post: file },
    };
  });
}

const { post } = Astro.props;
const { Content } = post;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{post.frontmatter.title}</title>
	</head>
	<body>
		<main class="post-wrapper">
			<a href="/" class="back-link">&larr; Back to Dashboard</a>
			
			<article class="blog-post">
				<header>
					<h1>{post.frontmatter.title}</h1>
					{post.frontmatter.description && <p class="desc">{post.frontmatter.description}</p>}
				</header>
				<hr />
				<div class="content">
					<Content />
				</div>
			</article>
		</main>
	</body>
</html>

<style>
	body {
		background-color: #0f172a;
		color: #f8fafc;
		font-family: system-ui, sans-serif;
		margin: 0;
		padding: 0;
	}
	.post-wrapper {
		max-w: 800px;
		margin: 0 auto;
		padding: 3rem 2rem;
	}
	.back-link {
		color: #38bdf8;
		text-decoration: none;
		font-size: 0.9rem;
		display: inline-block;
		margin-bottom: 2rem;
	}
	.back-link:hover {
		text-decoration: underline;
	}
	.blog-post h1 {
		font-size: 2.5rem;
		margin-bottom: 0.5rem;
		background: linear-gradient(to right, #38bdf8, #2dd4bf);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}
	.desc {
		color: #94a3b8;
		font-size: 1.2rem;
		line-height: 1.6;
	}
	hr {
		border: 0;
		border-top: 1px solid #334155;
		margin: 2rem 0;
	}
	.content {
		line-height: 1.8;
		color: #cbd5e1;
	}
	.content h1, .content h2 {
		color: #f8fafc;
	}
</style>